   ],
   "source": [
    "#| echo: true\n",
    "#| code-fold: true\n",
    "#| code-summary: \"See data loading\"\n",
    "\n",
    "from gwosc.datasets import event_gps\n",
    "from gwpy.timeseries import TimeSeries\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from tensorflow.keras import regularizers\n",
    "# Download real GW150914 data from LIGO H1 detector\n",
    "gps = event_gps('GW150914')\n",
    "segment = (gps - 16, gps + 16)\n",
    "\n",
    "H1 = TimeSeries.fetch_open_data('H1', *segment, verbose=False)\n",
    "print(f\"Sample rate: {H1.sample_rate}\")\n",
    "print(f\"Duration: {H1.duration}\")\n",
    "print(f\"GPS time of event: {gps}\")"
   ]
