   "source": [
    "## Dataset Generation\n",
    "\n",
    "We generate a balanced dataset of signal and noise segments:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "32a942a5",
   "metadata": {
    "cache": true
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Dataset shape: (1000, 33, 36, 1)\n",
      "Signal samples: 500, Noise samples: 500\n"
     ]
    }
   ],
   "source": [
    "#| echo: true\n",
    "#| code-fold: true\n",
    "#| code-summary: See dataset generation\n",
    "\n",
    "from scipy.signal import spectrogram\n",
    "import numpy as np\n",
    "\n",
    "def generate_spectrogram(data, fs=4096, nperseg=64):\n",
    "    _, _, Sxx = spectrogram(data, fs=fs, nperseg=nperseg)\n",
    "    Sxx = np.log1p(Sxx)\n",
    "    Sxx = (Sxx - Sxx.min()) / (Sxx.max() - Sxx.min())\n",
    "    return Sxx\n",
    "\n",
    "# Signal segments (around event)\n",
    "n_samples = 500\n",
    "segment_length = 0.5  # seconds\n",
    "fs = int(H1.sample_rate.value)\n",
    "n_points = int(segment_length * fs)\n",
    "\n",
    "X, y = [], []\n",
    "\n",
    "# Signal samples — around GW event\n",
    "event_idx = int((gps - H1.times.value[0]) * fs)\n",
    "for i in range(n_samples):\n",
    "    offset = np.random.randint(-n_points//2, n_points//2)\n",
    "    start = event_idx + offset\n",
    "    if start >= 0 and start + n_points < len(H1.value):\n",
    "        seg = H1.value[start:start+n_points]\n",
    "        spec = generate_spectrogram(seg, fs=fs)\n",
    "        X.append(spec)\n",
    "        y.append(1)\n",
    "\n",
    "# Noise samples — far from event\n",
    "for i in range(n_samples):\n",
    "    start = np.random.randint(0, len(H1.value) - n_points - event_idx - 1000)\n",
    "    seg = H1.value[start:start+n_points]\n",
    "    spec = generate_spectrogram(seg, fs=fs)\n",
    "    X.append(spec)\n",
    "    y.append(0)\n",
    "\n",
    "X = np.array(X)[..., np.newaxis]\n",
    "y = np.array(y)\n",
    "\n",
    "print(f\"Dataset shape: {X.shape}\")\n",
    "print(f\"Signal samples: {y.sum()}, Noise samples: {(y==0).sum()}\")"
   ]
  },
